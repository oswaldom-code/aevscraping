# Consolidator — configuración de la subida a la API (consolidator/lib/api.py).
# Copia este archivo a .env y completa los valores. NO commitees .env (está gitignoreado).
# Estas variables solo se usan al correr con --upload.

# Endpoint que recibe el .xlsx del delta
AEV_API_URL=https://aquiestoyvenezuela.com/api/post_carga_doc.php

# Clave de la API (header X-API-Key). Pídela al responsable; nunca la subas a git.
AEV_API_KEY=reemplazar-con-la-api-key

# Identificadores que la API espera en el multipart
AEV_ID_USUARIO=1
AEV_ID_HOSPITAL=1
