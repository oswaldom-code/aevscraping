# Ignorar logs
logs/

# Ignorar bases de datos locales y archivos de datos temporales en scrapers
Amilkir/**/*.json
Amilkir/**/*.csv
chiki/**/*.json
chiki/**/*.csv

# Conservar esquemas de BBDD que son archivos de configuración pequeños
!**/esquema-bbdd-sos-json*.json

# Para la carpeta de datos consolidados:
# Ignorar el JSON grande (141MB) y temporales de Excel
datos_consolidados/todos_registros.json
datos_consolidados/~*

# Consolidator: maestro SQLite regenerable y salidas de cada corrida
consolidator/master.db
consolidator/out/

# Python bytecode y entorno virtual
__pycache__/
*.pyc
.venv/

# Variables de entorno (la plantilla .env.example SÍ se versiona)
.env
